<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="#FFF5F5" />
            <stroke android:width="1dp" android:color="@color/secondaryColor" />
            <corners android:radius="2dp" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#EEEEEE" />
            <stroke android:width="1dp" android:color="@color/gray_300" />
            <corners android:radius="2dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/gray_50" />
            <stroke android:width="1dp" android:color="@color/gray_200" />
            <corners android:radius="2dp" />
        </shape>
    </item>
</selector>
